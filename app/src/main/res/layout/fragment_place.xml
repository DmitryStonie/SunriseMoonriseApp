<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/map"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/placeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="60dp"
        android:layout_marginHorizontal="100dp"
        android:padding="10dp"
        tools:text="Новосибирская область"
        android:textSize="@dimen/infoText"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="@color/white"
        android:textAlignment="center"
        android:background="@drawable/info_element_background"
        />

    <Button
        android:id="@+id/back"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginBottom="60dp"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:text="@string/back_button_text"
        app:icon="@drawable/arrow_left"
        app:iconSize="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/select"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <Button
        android:id="@+id/select"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginBottom="60dp"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:text="@string/select_button_text"
        app:icon="@drawable/check_01"
        app:iconSize="40dp"
        app:iconTint="@color/white"
        android:textColor="@color/white"
        app:backgroundTint="@color/green"
        app:layout_constraintStart_toEndOf="@+id/back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>